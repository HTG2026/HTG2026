# Site URL for SEO (sitemap, robots, Open Graph)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Weather — WeatherAPI.com allows commercial use (ads). Free at weatherapi.com.
# Without this, we use Open-Meteo (non-commercial only).
WEATHERAPI_KEY=

# Upstash Redis (for TikTok feed cache)
# Create at https://vercel.com/integrations/upstash
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: ScrapeCreators API for TikTok hashtag scraping
# https://scrapecreators.com
SCRAPECREATORS_API_KEY=

# Optional: Protect cron endpoint (Vercel cron sends vercel-cron user-agent)
CRON_SECRET=

# Optional: Eventbrite API for live Orlando events (https://www.eventbrite.com/platform/api/)
EVENTBRITE_TOKEN=

# Optional: Ticketmaster Discovery API for Dr Phillips, Kia Center, Hard Rock Live
# https://developer.ticketmaster.com/products-and-docs/apis/discovery-api/v2/
TICKETMASTER_API_KEY=

# Optional: Place photos (real photos instead of stock) — Google, Yelp, or Foursquare
# https://console.cloud.google.com/apis/credentials (enable Places API)
GOOGLE_PLACES_API_KEY=
# https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=
# https://foursquare.com/developers/signup
FOURSQUARE_API_KEY=
